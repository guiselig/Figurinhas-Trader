        <mxCell id="apns_box" value="APPLE PUSH NOTIF (APNs)&#xa;(iOS Notifications)&#xy;&#xa;Free, unlimited:&#xa;• Trade notifications&#xa;• Meetup reminders&#xa;• System messages&#xa;• Delivery rate: 99%&#xa;• Latency: &lt;3s" style="rounded=1;whiteSpace=wrap;html=1;fillColor#bbdefb;strokeColor#0d47a1;strokeWidth=2;fontSize=10;align=left;verticalAlign=top;padding=10;" vertex="1" parent="1">
          <mxGeometry x="960" y="930" width="200" height="130" as="geometry" />
        </mxCell>

        <!-- AdMob -->
        <mxCell id="admob_box" value="GOOGLE ADMOB&#xa;(Monetization)&#xy;&#xa;Free tier:&#xa;• Banner ads&#xa;• Interstitial (1/session)&#xa;• R$0.50-1.50 CPM&#xa;• Free users only&#xy;• No tracking" style="rounded=1;whiteSpace=wrap;html=1;fillColor#fff9c4;strokeColor#f57f17;strokeWidth=2;fontSize=10;align=left;verticalAlign=top;padding=10;" vertex="1" parent="1">
          <mxGeometry x="1180" y="930" width="200" height="130" as="geometry" />
        </mxCell>

        <!-- Monetization connections -->
        <mxCell id="rc_to_gplay" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontSize=8;strokeWidth=1.5;strokeColor#d84315;" edge="1" source="revenuecat_box" target="gplay_billing_box" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="rc_to_storekit" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontSize=8;strokeWidth=1.5;strokeColor#d84315;" edge="1" source="revenuecat_box" target="storekit_box" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ===== FLUXOS CRÍTICOS (RODAPÉ) ===== -->
        <mxCell id="flows_title" value="FLUXOS CRÍTICOS DE DADOS:" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1;fontColor#000;backgroundColor#f5f5f5;padding=5;" vertex="1" parent="1">
          <mxGeometry x="50" y="1080" width="1900" height="20" as="geometry" />
        </mxCell>

        <mxCell id="flow_1_text" value="① SCAN FIGURINHA: App camera → ML Kit (on-device) → classificação local → Supabase (user_stickers) → estado: 'have'" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontFamily=monospace;backgroundColor#fffde7;" vertex="1" parent="1">
          <mxGeometry x="50" y="1105" width="1900" height="18" as="geometry" />
        </mxCell>

        <mxCell id="flow_2_text" value="② CRIAR TRADE: App → Supabase.trades (insert) → Edge Function (match_algorithm) → n8n webhook → busca matches → FCM/APNs notificação" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontFamily=monospace;backgroundColor#e1f5fe;" vertex="1" parent="1">
          <mxGeometry x="50" y="1130" width="1900" height="18" as="geometry" />
        </mxCell>

        <mxCell id="flow_3_text" value="③ ASSINAR PREMIUM: App → RevenueCat SDK → Google Play/AppStore → RevenueCat webhook → n8n → Supabase (subscriptions.status='active') → Features unlock" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontFamily=monospace;backgroundColor#fff9c4;" vertex="1" parent="1">
          <mxGeometry x="50" y="1155" width="1900" height="18" as="geometry" />
        </mxCell>

        <mxCell id="flow_4_text" value="④ MEETUP REMINDER: n8n schedule (1h before) → Supabase (meetup_attendees) → FCM/APNs → 'Meetup em 1 hora!' → usuários confirmados" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontFamily=monospace;backgroundColor#f3e5f5;" vertex="1" parent="1">
          <mxGeometry x="50" y="1180" width="1900" height="18" as="geometry" />
        </mxCell>

        <mxCell id="flow_5_text" value="⑤ ANALYTICS: App events → PostHog SDK → servidor caseiro PostHog → funnels/retention/session replay → dashboard em https://posthog.figurinhatrader.com.br" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontFamily=monospace;backgroundColor#e1f5fe;" vertex="1" parent="1">
          <mxGeometry x="50" y="1205" width="1900" height="18" as="geometry" />
        </mxCell>

        <mxCell id="flow_6_text" value="⑥ AI ORCHESTRATOR: Gemini reads tasks.json → Prompts Opus → Opus reads code → Writes features → Commits to GitHub → State.json atualiza → Próxima tarefa (parallelism: 3 workers)" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontFamily=monospace;backgroundColor#fff3e0;" vertex="1" parent="1">
          <mxGeometry x="50" y="1230" width="1900" height="18" as="geometry" />
        </mxCell>

        <!-- Legend -->
        <mxCell id="legend_title" value="LEGENDA:" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=1;fontColor#000;" vertex="1" parent="1">
          <mxGeometry x="50" y="1260" width="1900" height="18" as="geometry" />
        </mxCell>

        <mxCell id="legend_items" value="🤖 = Automação IA  |  📱 = App Mobile  |  ☁️ = Cloud/Hosted  |  🖥️ = Self-hosted  |  💰 = Monetização  |  → = Fluxo de dados  |  ⟂ = Webhook  |  🔐 = Seguro" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=9;fontFamily=Arial;fontColor#666;" vertex="1" parent="1">
          <mxGeometry x="50" y="1280" width="1900" height="30" as="geometry" />
